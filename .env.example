# Backend
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
PORT=8493
JWT_Token=replace_with_long_random_secret
CLIENT_URL=http://localhost:5173
X_API_KEY=replace_with_random_api_key

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Use onboarding@resend.dev for testing (sends only to your Resend account email)
# For production add a verified domain at resend.com/domains
RESEND_FROM=onboarding@resend.dev
